{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": ["artisan", "boost:mcp"]
        },
        "shadcn": {
            "command": "npx",
            "args": ["shadcn@latest", "mcp"]
        },
        "lucide-icons": {
            "command": "npx",
            "args": ["lucide-icons-mcp", "--stdio"]
        }
    }
}
